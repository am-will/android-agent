# Copy to pc/.env.local (gitignored) so `npm run bridge` picks these up automatically.
# Real env vars set on the command line still win, so per-run overrides keep working.

PHONE_AGENT_HOST=0.0.0.0
PHONE_AGENT_PORT=8788
# Replace with the strong token from `npm run phone:tailscale` (or any shared secret you
# also save in the Android app). Both ends must match exactly.
PHONE_AGENT_TOKEN=replace-with-strong-token
PHONE_AGENT_DEFAULT_DEVICE=openclaw-agent
PHONE_AGENT_BRIDGE_URL=http://127.0.0.1:8788
PHONE_AGENT_DISPATCHER=openclaw
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_CHAT_AGENT_ID=main
OPENCLAW_CHAT_SESSION_KEY=agent:main:explicit:open-claw-agent
OPENCLAW_AGENT_COMMAND=openclaw
OPENCLAW_AGENT_SESSION_ID=open-claw-agent
OPENCLAW_AGENT_TIMEOUT_SECONDS=600
CODEX_APP_SERVER_COMMAND=codex app-server --listen stdio://
CODEX_AGENT_CWD=..
